                                    $difference =
                                        $entry->calculated_difference;

                                    $differenceClass = match (true) {
                                        $difference === null =>
                                            'wi-diff-neutral',
                                        (float) $difference > 0 =>
                                            'wi-diff-positive',
                                        (float) $difference < 0 =>
                                            'wi-diff-negative',
                                        default =>
                                            'wi-diff-neutral',
                                    };

                                    $entryTrend = match (
                                        $entry->calculated_trend
                                    ) {
                                        'gaining' => [
                                            'label' => 'Gaining',
                                            'icon' => '↗',
                                            'class' => 'trend-gaining',
                                        ],
                                        'losing' => [
                                            'label' => 'Losing',
                                            'icon' => '↘',
                                            'class' => 'trend-losing',
                                        ],
                                        'stable' => [
                                            'label' => 'Stable',
                                            'icon' => '→',
                                            'class' => 'trend-stable',
                                        ],
                                        default => [
                                            'label' => 'First Entry',
                                            'icon' => '●',
                                            'class' => 'trend-first',
                                        ],
                                    };
                                @endphp

                                <tr>
